# ============================================================
# Git ignore rules — prevents generated files, secrets, and
# OS artifacts from being committed to the repository.
# ============================================================

# --- Data files (generated by pipeline, not source-controlled) ---
# DuckLake catalog file (binary, rebuilt by pipeline)
data/chronos.ducklake          

# DuckLake Parquet data files (rebuilt by pipeline)
data/chronos.ducklake.files/   

# DuckDB database files (binary, large, rebuilt by pipeline)
*.duckdb                      

# DuckDB write-ahead log (temporary, rebuilt)
*.duckdb.wal                  

# Parquet files (generated by Dagster/dbt, not source-controlled)
*.parquet            

# --- Python artifacts ---
# uv virtual environment (rebuilt by `uv sync`)
.venv/               

# Python bytecode cache (rebuilt on import)
__pycache__/         

# Compiled Python files
*.pyc                

# Python package metadata (rebuilt on install)
*.egg-info/          

# Python distribution artifacts
dist/                

# Python build artifacts
build/               

# --- dbt artifacts ---
# dbt compiled SQL, manifest.json, run results (rebuilt by `dbt build`)
dbt_project/target/
!dbt_project/manifest.json

# dbt installed packages (rebuilt by `dbt deps`)
dbt_project/dbt_packages/

# dbt execution logs
dbt_project/logs/
logs/

# --- Dagster artifacts ---
# Dagster run history, event logs, sensor state - SQLite, rebuilt on start
dagster_home/
!dagster_home/dagster.yaml

# --- IDE files ---
# JetBrains IDE config
.idea/               

# VS Code config
.vscode/             

# Vim swap files
*.swp                

# --- OS files ---
# macOS folder metadata
.DS_Store            

# Windows thumbnail cache
Thumbs.db            

# --- Secrets ---
# Environment variables (contains DAGSTER_HOME, tokens)
.env                 

# MotherDuck auth token (Phase 2)
.motherduck_token