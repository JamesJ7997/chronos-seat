# ============================================================
# Git ignore rules — prevents generated files, secrets, and
# OS artifacts from being committed to the repository.
# ============================================================

# --- Data files (generated by pipeline, not source-controlled) ---
data/chronos.ducklake          # DuckLake catalog file (binary, rebuilt by pipeline)
data/chronos.ducklake.files/   # DuckLake Parquet data files (rebuilt by pipeline)
*.duckdb                       # DuckDB database files (binary, large, rebuilt by pipeline)
*.duckdb.wal                   # DuckDB write-ahead log (temporary, rebuilt)
*.parquet            # Parquet files (generated by Dagster/dbt, not source-controlled)

# --- Python artifacts ---
.venv/               # uv virtual environment (rebuilt by `uv sync`)
__pycache__/         # Python bytecode cache (rebuilt on import)
*.pyc                # Compiled Python files
*.egg-info/          # Python package metadata (rebuilt on install)
dist/                # Python distribution artifacts
build/               # Python build artifacts

# --- dbt artifacts ---
dbt_project/target/       # dbt compiled SQL, manifest.json, run results (rebuilt by `dbt build`)
dbt_project/dbt_packages/ # dbt installed packages (rebuilt by `dbt deps`)
dbt_project/logs/         # dbt execution logs

# --- Dagster artifacts ---
# Dagster run history, event logs, sensor state - SQLite, rebuilt on start
dagster_home/
!dagster_home/dagster.yaml


# --- IDE files ---
.idea/               # JetBrains IDE config
.vscode/             # VS Code config
*.swp                # Vim swap files

# --- OS files ---
.DS_Store            # macOS folder metadata
Thumbs.db            # Windows thumbnail cache

# --- Secrets ---
.env                 # Environment variables (contains DAGSTER_HOME, tokens)
.motherduck_token    # MotherDuck auth token (Phase 2)

